<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ═══════════════════════════════════════════════════════════════
             Groups (re-use Odoo accounting groups; no new groups needed)
             ═══════════════════════════════════════════════════════════════ -->

        <!-- ═══════════════════════════════════════════════════════════════
             financehub.saved.config – record rules
             ═══════════════════════════════════════════════════════════════ -->

        <!-- All accounting users can READ configs that are either their own
             or shared -->
        <record id="rule_saved_config_read" model="ir.rule">
            <field name="name">FinanceHub Saved Config: Read own or shared</field>
            <field name="model_id" ref="model_financehub_saved_config"/>
            <field name="domain_force">
                ['|',
                 ('owner_id', '=', user.id),
                 ('sharing', '=', 'shared')]
            </field>
            <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Only owners (or managers) can WRITE/CREATE/DELETE their configs -->
        <record id="rule_saved_config_write" model="ir.rule">
            <field name="name">FinanceHub Saved Config: Write own only</field>
            <field name="model_id" ref="model_financehub_saved_config"/>
            <field name="domain_force">[('owner_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Managers can read/write any saved config -->
        <record id="rule_saved_config_manager" model="ir.rule">
            <field name="name">FinanceHub Saved Config: Manager full access</field>
            <field name="model_id" ref="model_financehub_saved_config"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('account.group_account_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- ═══════════════════════════════════════════════════════════════
             financehub.report.definition – record rules
             ═══════════════════════════════════════════════════════════════ -->

        <!-- Read: own or public definitions -->
        <record id="rule_report_def_read" model="ir.rule">
            <field name="name">FinanceHub Report Def: Read own or public</field>
            <field name="model_id" ref="model_financehub_report_definition"/>
            <field name="domain_force">
                ['|',
                 ('owner_id', '=', user.id),
                 ('is_public', '=', True)]
            </field>
            <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Write: only owner -->
        <record id="rule_report_def_write" model="ir.rule">
            <field name="name">FinanceHub Report Def: Write own only</field>
            <field name="model_id" ref="model_financehub_report_definition"/>
            <field name="domain_force">[('owner_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Manager: full access to all definitions -->
        <record id="rule_report_def_manager" model="ir.rule">
            <field name="name">FinanceHub Report Def: Manager full access</field>
            <field name="model_id" ref="model_financehub_report_definition"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('account.group_account_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- ═══════════════════════════════════════════════════════════════
             financehub.reconciliation.note – record rules
             ═══════════════════════════════════════════════════════════════ -->

        <!-- Notes are read-only; only managers can delete -->
        <record id="rule_recon_note_user" model="ir.rule">
            <field name="name">FinanceHub Recon Note: User read access</field>
            <field name="model_id" ref="model_financehub_reconciliation_note"/>
            <field name="domain_force">[('company_id', 'in', user.company_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_recon_note_manager" model="ir.rule">
            <field name="name">FinanceHub Recon Note: Manager full access</field>
            <field name="model_id" ref="model_financehub_reconciliation_note"/>
            <field name="domain_force">[('company_id', 'in', user.company_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('account.group_account_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>
